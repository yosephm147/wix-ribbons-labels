# Loaded automatically: repo root .env / .env.local, then this folder’s .env / .env.local (later wins).
# Same connection string as the Wix app (see repo root .env).
DATABASE_URL=postgresql://user:pass@localhost:5432/your_db

# Optional (default 3000). Use with ngrok: ngrok http 3000
# PORT=3000

# Optional — match src/lib/db.ts when using cloud Postgres
# NODE_ENV=production
# PGSSLMODE=require
